{
  "functions": {
    "api/**/*": {
      "includeFiles": "{node_modules/.prisma/client/**/*,dist/index.html,index.html}",
      "memory": 1024,
      "maxDuration": 60,
      "regions": ["sin1"]
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(ico|png|jpg|jpeg|svg|webp|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/pdf-editor", "destination": "/index.html" },
    { "source": "/pdf-merge-split", "destination": "/index.html" },
    { "source": "/pdf-compressor", "destination": "/index.html" },
    { "source": "/pdf-to-image", "destination": "/index.html" },
    { "source": "/image-compressor", "destination": "/index.html" },
    { "source": "/qr-link", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/tao-khung", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/register", "destination": "/index.html" },
    { "source": "/f/(.*)", "destination": "/api/frame-og?slug=$1" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/:alias", "destination": "/api/redirect?alias=:alias" }
  ]
}
